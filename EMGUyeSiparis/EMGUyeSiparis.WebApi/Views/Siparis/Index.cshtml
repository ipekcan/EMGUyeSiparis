@model IEnumerable<EMGUyeSiparis.WebApi.Models.SiparisOzetViewModel>

@{
    ViewData["Title"] = "Sipariş Listesi";
    
    // Tüm sayfadaki genel istatistikleri liste üzerinden hesaplıyoruz
    var sayfaGenelToplamCiro = Model.Sum(s => s.GenelToplamTutar);
    var sayfaGenelToplamAdet = Model.Sum(s => s.ToplamUrunAdeti);
    var toplamSiparisSayisi = Model.Count();
}

<div class="container mt-4">
    <!-- Üst Başlık ve Yeni Sipariş Butonu -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-receipt-cutoff text-primary"></i> Sipariş Yönetim Paneli</h2>
        <a asp-action="Create" class="btn btn-success fw-bold px-4 py-2 shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i> Yeni Sipariş Oluştur
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm" role="alert">
            <i class="bi bi-info-circle-fill me-2 fs-5"></i> Henüz sisteme kayıtlı bir sipariş bulunamadı.
        </div>
    }
    else
    {
        <!-- Sipariş Kartları Başlangıcı (Accordion Yapısı) -->
        <div class="accordion shadow-sm mb-4" id="siparisAccordion">
            @foreach (var siparis in Model)
            {
                var collapseId = "collapse_" + siparis.SiparisOzetId;
                var headingId = "heading_" + siparis.SiparisOzetId;

                <div class="accordion-item mb-3 border rounded">
                    <!-- Akordeon Başlığı (Sipariş Özeti Bilgileri) -->
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed bg-light text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            <div class="row w-100 align-items-center text-start m-0">
                                <div class="col-md-2 col-6">
                                    <span class="badge bg-secondary px-3 py-2 fw-bold">#@siparis.SiparisOzetId</span>
                                </div>
                                <div class="col-md-3 col-6 text-muted">
                                    <i class="bi bi-calendar3 me-2"></i>@siparis.Tarih.ToString("dd.MM.yyyy")
                                </div>
                                <div class="col-md-4 col-12 mt-2 mt-md-0">
                                    <div class="fw-bold fs-5">@siparis.UyeIsim</div>
                                    <small class="text-muted d-block">@siparis.Unvan</small>
                                </div>
                                <div class="col-md-3 col-12 text-md-end mt-2 mt-md-0 text-success fw-bold fs-5">
                                    Toplam: @siparis.GenelToplamTutar.ToString("C2")
                                </div>
                            </div>
                        </button>
                    </h2>

                    <!-- Akordeon İçeriği (Sipariş Alt Detay Tablosu) -->
                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#siparisAccordion">
                        <div class="accordion-body bg-white p-4 border-top">
                            <h5 class="mb-3 text-secondary"><i class="bi bi-box-seam me-2"></i>Sipariş Verilen Ürünler (@siparis.ToplamUrunAdeti Parça)</h5>
                            
                            <div class="table-responsive">
                                <table class="table table-hover table-striped table-bordered align-middle">
                                    <thead class="table-light text-center text-muted">
                                        <tr>
                                            <th>Ürün Adı</th>
                                            <th>Beden</th>
                                            <th>Adet</th>
                                            <th>Birim Fiyat</th>
                                            <th>Toplam Tutar</th>
                                            <th>Kan Grubu Bilgisi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var detay in siparis.Detaylar)
                                        {
                                            <tr>
                                                <td><span class="fw-bold text-dark">@detay.Urun</span></td>
                                                <td class="text-center"><span class="badge bg-secondary px-3 py-1">@detay.Beden</span></td>
                                                <td class="text-center fw-bold text-primary">@detay.Adet Adet</td>
                                                <td class="text-end font-monospace">@detay.BirimFiyat.ToString("C2")</td>
                                                <td class="text-end fw-bold text-success font-monospace">@detay.ToplamTutar.ToString("C2")</td>
                                                <td class="text-center">
                                                    <span class="badge bg-danger px-3 py-1">@detay.KanGrubu</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Sipariş İşlemleri / Silme Butonu -->
                            <div class="d-flex justify-content-end mt-3 pt-3 border-top">
                                <form asp-action="Delete" asp-route-id="@siparis.SiparisOzetId" method="post" onsubmit="return confirm('#@siparis.SiparisOzetId nolu siparişi ve bağlı tüm ürün detaylarını silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm px-4">
                                        <i class="bi bi-trash-fill me-1"></i> Siparişi İptal Et (Sil)
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- YENİ EKLENEN ALT TOPLAM / DASHBOARD ALANI -->
        <div class="card bg-dark text-white shadow-sm border-0 rounded">
            <div class="card-body p-4">
                <div class="row align-items-center text-center text-md-start">
                    <div class="col-md-3 mb-3 mb-md-0 border-end border-secondary border-sm-0">
                        <div class="text-muted small uppercase fw-bold text-info">Toplam Sipariş</div>
                        <div class="fs-3 fw-bold">@toplamSiparisSayisi Adet Kayıt</div>
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0 border-end border-secondary border-sm-0">
                        <div class="text-muted small uppercase fw-bold text-warning">Toplam Satılan Ürün</div>
                        <div class="fs-3 fw-bold text-warning">@sayfaGenelToplamAdet Adet</div>
                    </div>
                    <div class="col-md-5 text-md-end">
                        <div class="text-muted small uppercase fw-bold text-success">GENEL ALT TOPLAM (CİRO)</div>
                        <div class="fs-2 fw-bolder text-success">@sayfaGenelToplamCiro.ToString("C2")</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
