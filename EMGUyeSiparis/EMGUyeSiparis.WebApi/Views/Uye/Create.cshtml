@model EMGUyeSiparis.WebApi.Models.Uye

@{
    ViewData["Title"] = "Yeni Üye Ekle";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-person-plus-fill text-success"></i> Yeni Üye Ekle</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Listeye Dön
        </a>
    </div>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- İsim Alanı -->
                <div class="form-group mb-3">
                    <label asp-for="Isim" class="control-label fw-bold mb-1">İsim Ad Soyad</label>
                    <input asp-for="Isim" class="form-control" placeholder="Üyenin adını ve soyadını giriniz" required />
                    <span asp-validation-for="Isim" class="text-danger"></span>
                </div>

                <!-- Ünvan Alanı -->
                <div class="form-group mb-3">
                    <label asp-for="Unvan" class="control-label fw-bold mb-1">Ünvan</label>
                    <input asp-for="Unvan" class="form-control" placeholder="Örn: Mühendis, Öğrenci, Yönetici" required />
                    <span asp-validation-for="Unvan" class="text-danger"></span>
                </div>

                <!-- Kan Grubu Alanı -->
                <div class="form-group mb-4">
                    <label asp-for="KanGrubu" class="control-label fw-bold mb-1">Kan Grubu (İsteğe Bağlı)</label>
                    <select asp-for="KanGrubu" class="form-control" asp-items="ViewBag.KanGruplari">
                        <option value="">-- Kan Grubu Seçiniz --</option>
                    </select>
                    <span asp-validation-for="KanGrubu" class="text-danger"></span>
                </div>

                <!-- Butonlar -->
                <div class="form-group">
                    <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>Üyeyi Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-light border px-4 ms-2">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
