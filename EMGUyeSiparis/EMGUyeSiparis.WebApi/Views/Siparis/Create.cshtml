@model EMGUyeSiparis.WebApi.Models.SiparisKayitViewModel

@{
    ViewData["Title"] = "Çoklu Sipariş Oluştur";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-cart-plus-fill text-success"></i> Çoklu Sipariş Oluştur</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Listeye Dön
        </a>
    </div>
    <hr />

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Üye ve Sipariş Tarihi Seçim Alanı -->
        <div class="row mb-4">
            <div class="col-md-4 col-sm-6">
                <div class="form-group">
                    <label class="control-label fw-bold mb-1"><i class="bi bi-person-fill text-secondary"></i> Siparişi
                        Veren Üye</label>
                        <select asp-for="UyeId" class="form-control" asp-items="ViewBag.UyeId" required>
                            <option value="">-- Üye Seçiniz --</option>
                        </select>
                        <span asp-validation-for="UyeId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="form-group">
                        <label class="control-label fw-bold mb-1"><i class="bi bi-calendar-event text-secondary"></i>
                            Sipariş Tarihi</label>
                            <!-- HTML5 Date Picker: Değer biçimi C# DateOnly için yyyy-MM-dd olmalıdır -->
                            <input type="date" asp-for="Tarih" class="form-control"
                                   value="@Model?.Tarih.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString(" yyyy-MM-dd")" required />
                            <span asp-validation-for="Tarih" class="text-danger"></span>
                        </div>
                    </div>
                </div>



                <h4 class="text-secondary mb-3"><i class="bi bi-box-seam me-2"></i>Sipariş Verilecek Ürünler</h4>

                <!-- Dinamik Ürün Tablosu -->
                <div class="table-responsive">
                    <table class="table table-bordered align-middle shadow-sm" id="urunTablosu">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 30%;">Ürün</th>
                                <th style="width: 15%;">Beden</th>
                                <th style="width: 15%;">Adet</th>
                                <th style="width: 25%;">Kan Grubu (İsteğe Bağlı)</th>
                                <th style="width: 15%; text-align: center;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- İlk satır varsayılan olarak gelir (İndeks: 0) -->
                            <tr class="urun-satiri">
                                <td>
                                    <select name="Urunler[0].Urun" class="form-control" asp-items="ViewBag.Urunler" required>
                                        <option value="">-- Ürün Seçiniz --</option>
                                    </select>
                                </td>
                                <td>
                                    <select name="Urunler[0].Beden" class="form-control" asp-items="ViewBag.Bedenler" required>
                                        <option value="">-- Beden --</option>
                                    </select>
                                </td>
                                <td>
                                    <input name="Urunler[0].Adet" type="number" class="form-control text-center" min="1"
                                           value="1" required />
                                </td>
                                <td>
                                    <select name="Urunler[0].KanGrubu" class="form-control" asp-items="ViewBag.KanGruplari">
                                        <option value="">-- Kan Grubu --</option>
                                    </select>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-outline-danger btn-sm satiri-sil" disabled>
                                        <i class="bi bi-trash"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Alt Butonlar -->
                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-outline-primary fw-bold px-3" id="yeniSatirEkle">
                        <i class="bi bi-plus-lg"></i> Başka Bir Ürün Ekle
                    </button>
                    <div>
                        <a asp-action="Index" class="btn btn-light border me-2 px-4">İptal</a>
                        <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i>Siparişi Tamamla
                        </button>
                    </div>
                </div>
            </form>
        </div>

        @section Scripts {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    // İlk satır indeks 0 olduğu için, eklenecek sonraki satır 1'den başlar
                    let satirIndex = 1;

                    // "Başka Bir Ürün Ekle" Butonuna Tıklanınca
                    document.getElementById("yeniSatirEkle").addEventListener("click", function () {
                        let tabloGovdesi = document.querySelector("#urunTablosu tbody");
                        let ilkSatir = tabloGovdesi.querySelector(".urun-satiri");

                        // İlk satırı şablon olarak klonla
                        let yeniSatir = ilkSatir.cloneNode(true);

                        // Klonlanan satırdaki elemanların name niteliklerini yeni indekse göre güncelle
                        yeniSatir.querySelectorAll("select, input").forEach(function (element) {
                            let eskiAd = element.getAttribute("name"); // Örn: Urunler[0].Urun

                            // Düzenli ifade (Regex) ile [0] olan kısmı [satirIndex] yapar
                            let yeniAd = eskiAd.replace(/\[\d+\]/, "[" + satirIndex + "]");
                            element.setAttribute("name", yeniAd);

                            // Yeni eklenen satırdaki değerleri varsayılana çek
                            if (element.tagName === "INPUT") {
                                element.value = 1;
                            } else {
                                element.selectedIndex = 0;
                            }
                        });

                        // Yeni satırdaki silme butonunu kilidini aç ve kullanılabilir yap
                        let silButonu = yeniSatir.querySelector(".satiri-sil");
                        silButonu.removeAttribute("disabled");

                        // Satırı tabloya ekle ve ana indeksi artır
                        tabloGovdesi.appendChild(yeniSatir);
                        satirIndex++;
                    });

                    // "Sil" Butonuna Tıklanınca
                    document.querySelector("#urunTablosu").addEventListener("click", function (e) {
                        if (e.target.classList.contains("satiri-sil") || e.target.closest(".satiri-sil")) {
                            let buton = e.target.classList.contains("satiri-sil") ? e.target : e.target.closest(".satiri-sil");
                            let satirlar = document.querySelectorAll(".urun-satiri");

                            // Tabloda en az 1 satır kalmasını garanti altına al
                            if (satirlar.length > 1) {
                                buton.closest(".urun-satiri").remove();
                                satirIndeksleriniYenidenDuzenle();
                            }
                        }
                    });

                    // Satır silindiğinde indekslerin sırasının bozulmaması için (0, 1, 2...) yeniden yapılandırır
                    function satirIndeksleriniYenidenDuzenle() {
                        let i = 0;
                        document.querySelectorAll(".urun-satiri").forEach(function (satir) {
                            satir.querySelectorAll("select, input").forEach(function (element) {
                                let eskiAd = element.getAttribute("name");
                                let yeniAd = eskiAd.replace(/\[\d+\]/, "[" + i + "]");
                                element.setAttribute("name", yeniAd);
                            });
                            i++;
                        });
                        satirIndex = i; // Genel indeks sayacını güncelle
                    }
                });
            </script>
        }
