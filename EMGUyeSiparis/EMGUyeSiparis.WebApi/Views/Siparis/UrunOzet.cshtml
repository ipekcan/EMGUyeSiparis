@model IEnumerable<EMGUyeSiparis.WebApi.Models.UrunOzetViewModel>

@{
    ViewData["Title"] = "Ürün Bazlı Sipariş Raporu";
    var genelToplamCiro = Model.Sum(x => x.ToplamCiro);
    var genelToplamAdet = Model.Sum(x => x.ToplamSatishAdedi);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-pie-chart-fill text-info"></i> Ürün Bazında Sipariş Özetleri</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Sipariş Paneline Dön
        </a>
    </div>

    <!-- Hızlı İstatistik Kartları -->
    <div class="row mb-4">
        <div class="col-md-6 mb-3 mb-md-0">
            <div class="card bg-primary text-white shadow-sm border-0">
                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small text-uppercase fw-bold text-white-50">Toplam Teslim Edilecek Ürün</div>
                        <div class="fs-2 fw-bold">@genelToplamAdet Adet</div>
                    </div>
                    <i class="bi bi-box-seam fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-success text-white shadow-sm border-0">
                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small text-uppercase fw-bold text-white-50">Toplam Brüt Ciro</div>
                        <div class="fs-2 fw-bold">@genelToplamCiro.ToString("C2")</div>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Henüz sipariş alınmış bir ürün bulunmuyor.
        </div>
    }
    else
    {
        <!-- Ürün Kartları Akordeon Yapısı -->
        <div class="accordion shadow-sm" id="urunAccordion">
            @for (int i = 0; i < Model.Count(); i++)
            {
                var urun = Model.ElementAt(i);
                var collapseId = "collapseUrun_" + i;
                var headingId = "headingUrun_" + i;

                <div class="accordion-item mb-3 border rounded shadow-xs">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed bg-light text-dark" type="button" data-bs-toggle="collapse"
                                data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            <div class="row w-100 align-items-center text-start m-0">
                                <div class="col-md-4 col-12 fw-bold fs-5 text-dark">
                                    <i class="bi bi-tag-fill text-secondary me-2"></i>@urun.UrunAdi
                                </div>
                                <div class="col-md-3 col-4 text-muted">
                                    Birim Fiyat: <span class="fw-bold">@urun.BirimFiyat.ToString("C2")</span>
                                </div>
                                <div class="col-md-2 col-4 text-center">
                                    Toplam Adet: <span class="badge bg-primary px-3 py-2">@urun.ToplamSatishAdedi Adet</span>
                                </div>
                                <div class="col-md-3 col-4 text-md-end text-success fw-bold fs-5">
                                    Toplam Kazanç: @urun.ToplamCiro.ToString("C2")
                                </div>
                            </div>
                        </button>
                    </h2>

                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId"
                         data-bs-parent="#urunAccordion">
                        <div class="accordion-body bg-white p-4 border-top">
                            <h6 class="text-secondary mb-3"><i class="bi bi-people me-2"></i>Bu Ürünü Sipariş Eden Üyeler</h6>

                            <div class="table-responsive">
                                <table class="table table-sm table-hover table-striped table-bordered align-middle">
                                    <thead class="table-light text-center text-muted small">
                                        <tr>
                                            <th>Sipariş No</th>
                                            <th>Tarih</th>
                                            <th>Üye Adı</th>
                                            <th>Beden</th>
                                            <th>Adet</th>
                                            <th>Tutar</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var alici in urun.SiparisVerenler)
                                        {
                                            <tr>
                                                <td class="text-center fw-bold text-secondary">#@alici.SiparisNo</td>
                                                <td class="text-center small">@alici.Tarih.ToString("dd.MM.yyyy")</td>
                                                <td><i class="bi bi-person me-1"></i>@alici.UyeIsim</td>
                                                <td class="text-center"><span class="badge bg-secondary">@alici.Beden</span></td>
                                                <td class="text-center fw-bold text-primary">@alici.Adet</td>
                                                <td class="text-end fw-bold text-success font-monospace">@((urun.BirimFiyat *
                                                                                            alici.Adet).ToString("C2"))</td>
        </tr>
    }
</tbody>
</table>
</div>
</div>
</div>
</div>
            }
</div>
    }
</div>
