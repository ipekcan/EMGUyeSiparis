@model IEnumerable<EMGUyeSiparis.WebApi.Models.Uye>

@{
    ViewData["Title"] = "Üye Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Kayıtlı Üyeler</h2>
        <a asp-action="Create" class="btn btn-success">Yeni Üye Ekle</a>
    </div>

    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>İsim</th>
                <th>Ünvan</th>
                <th>Kan Grubu</th>
                <th style="width: 180px;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Isim</td>
                    <td>@item.Unvan</td>
                    <td>
                        <span class="badge bg-danger">@(item.KanGrubu ?? "Belirtilmedi")</span>
                    </td>
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu üyeyi silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
